<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html b:css='false' b:defaultmessages='true' b:layoutsVersion='3' expr:dir='data:blog.languageDirection' expr:lang='data:blog.locale' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>
<head>
    <script type='text/javascript'>//<![CDATA[
        (function() {
            var cachedTheme = localStorage.getItem('antinna-theme');
            var systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (cachedTheme === 'dark' || (!cachedTheme && systemPrefersDark)) {
                document.documentElement.classList.add('dark');
            }
        })();
    //]]></script>

    <meta charset='UTF-8'/>
    <meta content='width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover' name='viewport'/>
    <title><data:blog.pageTitle/></title>
    
    <b:skin><![CDATA[ /* PASTE YOUR CSS HERE */ ]]></b:skin>
</head>
<body>

    <div id='sidebar-backdrop' onclick='toggleSidebarDrawer()'/>

    <div class='app-container'>
        <aside id='sidebar-drawer'>
            <div class='sidebar-header'>
                <div class='brand-logo'>
                    <span class='brand-icon'>A</span>
                    <span class='brand-text'>Antinna</span>
                </div>
                <button class='btn-close-sidebar' onclick='toggleSidebarDrawer()'>&#215;</button>
            </div>

            <div class='sidebar-scroll-content'>
                <!-- Workspace -->
                <b:section class='sidebar-modules-section' id='sidebar-workspace-links' showaddelement='yes'>
                    <b:widget id='LinkList3' locked='false' title='Workspace Menu' type='LinkList' version='2'>
                        <b:includable id='main'>
                            <div class='module-wrapper'>
                                <button class='module-trigger' onclick='toggleModuleDropdown("workspace-module")'>
                                    <span>Workspace Options</span>
                                    <span class='arrow-indicator' id='workspace-module-arrow'>▾</span>
                                </button>
                                <ul class='module-dropdown-list' id='workspace-module'>
                                    <b:loop values='data:links' var='link'>
                                        <li><a class='nav-route-link' expr:href='data:link.target'><data:link.name/></a></li>
                                    </b:loop>
                                </ul>
                            </div>
                        </b:includable>
                    </b:widget>
                </b:section>

                <!-- Legal -->
                <b:section class='sidebar-legal-section' id='sidebar-legal-links' showaddelement='yes'>
                    <b:widget id='LinkList2' locked='false' title='Legal Pages Menu' type='LinkList' version='2'>
                        <b:includable id='main'>
                            <div class='module-wrapper'>
                                <button class='module-trigger' onclick='toggleModuleDropdown("legal-policy-module")'>
                                    <span>Policies &amp; Legal</span>
                                    <span class='arrow-indicator' id='legal-policy-module-arrow'>▾</span>
                                </button>
                                <ul class='module-dropdown-list ui-hidden' id='legal-policy-module'>
                                    <b:loop values='data:links' var='link'>
                                        <li><a class='nav-route-link' expr:href='data:link.target'><data:link.name/></a></li>
                                    </b:loop>
                                </ul>
                            </div>
                        </b:includable>
                    </b:widget>
                </b:section>
            </div>

            <div class='avatar-footer-row'>
                <div class='avatar-left-info'>
                    <div class='user-avatar-circle'><span>U</span></div>
                    <div class='user-meta-strings'>
                        <span class='user-display-name'>Guest User</span>
                        <span class='user-display-role'>Workspace Client</span>
                    </div>
                </div>
            </div>
        </aside>

        <div class='main-view-wrapper'>
            <header class='top-navbar-header'>
                <button class='btn-hamburger' onclick='toggleSidebarDrawer()'>&#9776;</button>
                <div class='header-center-search'>
                     <form action='/search' method='get'><input class='search-input' name='q' placeholder='Search...' type='text'/></form>
                </div>
                <button class='btn-theme-toggle' id='theme-mode-switcher'>
                    <span class='mode-icon icon-moon'>&#9790;</span>
                    <span class='mode-icon icon-sun ui-hidden'>&#9728;</span>
                </button>
            </header>

            <main class='scrollable-main-content'>
                <b:section id='main-feed-stream' showaddelement='no'/>
            </main>

            <b:section class='mobile-bottom-navigation-bar' id='sidebar-widgets' showaddelement='yes'>
                <b:widget id='LinkList1' locked='false' title='Navigation Menu' type='LinkList' version='2'>
                    <b:includable id='main'>
                        <ul class='bottom-nav-list'>
                            <b:loop values='data:links' var='link'>
                                <li class='bottom-nav-item'><a class='nav-route-link' expr:href='data:link.target'><data:link.name/></a></li>
                            </b:loop>
                        </ul>
                    </b:includable>
                </b:widget>
            </b:section>
        </div>
    </div>
    <script type='text/javascript'>//<![CDATA[ /* PASTE YOUR JS HERE */ //]]></script>
</body>
</html>
